# Copie para .env.local (dev) e configure as mesmas no painel da Vercel (Settings → Environment Variables).
# Todas são lidas em tempo de BUILD — após alterar na Vercel, refaça o deploy.

# Chave da API Gemini (Google AI Studio → aistudio.google.com/apikey)
GEMINI_API_KEY=

# URL do Web App do Apps Script (termina em /exec). Vazio = app usa só localStorage.
VITE_SHEETS_API_URL=

# Token opcional para a API da planilha (igual à constante TOKEN no apps-script/Code.gs)
VITE_SHEETS_API_TOKEN=
