# ===== Banco =====
# LOCAL (SQLite):
#   DATABASE_PROVIDER=sqlite
#   DATABASE_URL="file:./dev.db"
#
# VERCEL / PRODUÇÃO (PostgreSQL — Supabase, Neon, Vercel Postgres):
#   DATABASE_PROVIDER=postgresql
#   DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
#   Depois: npx prisma migrate deploy
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# ===== Auth.js (next-auth v5) =====
# Gerar com: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3030"
AUTH_TRUST_HOST="true"

# ===== Criptografia do cofre de tokens (src/lib/crypto.ts) =====
# OBRIGATÓRIO em uso real. Gerar com: openssl rand -hex 32  (32 bytes => 64 chars hex)
# Sem isto, crypto.ts cai no fallback de dev e os tokens quebram entre restarts.
ENCRYPTION_KEY=""

# ===== Google OAuth (Calendar + Drive) =====
# Google Cloud Console > Credentials > OAuth Client ID (Web)
# Redirect URI: http://localhost:3030/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===== Jobs / Cron =====
# Segredo p/ proteger /api/cron/*. Gerar com: openssl rand -hex 24
# Disparar: curl -H "Authorization: Bearer $CRON_SECRET" http://localhost:3030/api/cron/sync
CRON_SECRET=""

# ===== Nutrição (IA opcional) =====
# Chave do Gemini (Google AI Studio). Usada SOMENTE no servidor (não vai ao cliente).
# Sem ela, o app funciona normalmente; só o "Descrever refeição (IA)" fica desativado.
GEMINI_API_KEY=""

# Backend de planilha (Apps Script) — sync de nutrição/água
SHEETS_API_URL=
SHEETS_API_TOKEN=
