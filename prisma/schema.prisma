generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== Auth.js =====
model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?
  timezone      String   @default("America/Sao_Paulo")
  createdAt     DateTime @default(now())

  // Auth local
  passwordHash  String?
  lastBackupAt  DateTime?
  role          String   @default("user") // user | admin

  // Perfil físico para nutrição
  sex           String?
  age           Int?
  heightCm      Int?
  weightKg      Float?
  activityLevel String?
  goal          String?
  targetKcal    Int?
  targetProtein Int?
  targetCarbs   Int?
  targetFat     Int?

  // Social
  handle        String?  @unique
  bio           String?
  avatarUrl     String?

  // Lembrete de hidratação
  wakeTime               String?  // "HH:mm" — horário que acorda
  waterReminderInterval  Int?     // minutos entre lembretes
  waterReminderEnabled   Boolean  @default(false)

  accounts      Account[]
  sessions      Session[]
  tasks         Task[]
  waterLogs     WaterLog[]
  meals         Meal[]
  foods         Food[]
  events        CalendarEvent[]
  integrations  Integration[]
  goals         Goal[]
  habits        Habit[]
  finAccounts   FinAccount[]
  transactions  Transaction[]
  budgets       Budget[]
  alarms        Alarm[]
  notifRules    NotificationRule[]

  // Social relations
  friendsSent       Friendship[]      @relation("sent")
  friendsReceived   Friendship[]      @relation("received")
  squadMemberships  SquadMember[]
  sentMessages      Message[]
  reactions         Reaction[]
  activitySessions  ActivitySession[]
  scores            UserScore[]
  badges            Badge[]

  // Estudos
  studySubjects     StudySubject[]
  studySessions     StudySession[]
  studySettings     StudySettings?

  // Dieta (perfil + planos gerados)
  dietProfile       DietProfile?
  dietPlans         DietPlan[]
}

model Account { 
  id String @id @default(cuid()) 
  userId String 
  provider String 
  providerAccountId String 
  type String 
  refresh_token String? 
  access_token String? 
  expires_at Int? 
  token_type String? 
  scope String?
  id_token String?
  session_state String?
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session { 
  id String @id @default(cuid()) 
  sessionToken String @unique 
  userId String 
  expires DateTime 
  user User @relation(fields:[userId], references:[id], onDelete: Cascade) 
}

model VerificationToken { 
  identifier String 
  token String @unique 
  expires DateTime 
  @@unique([identifier, token]) 
}

// ===== Integrações =====
model Integration {
  id            String   @id @default(cuid())
  userId        String
  provider      String   // google | outlook | canvas | discord
  label         String?  // ex.: "Google Pessoal", "Outlook Trabalho"
  accessToken   String?  // CRIPTOGRAFADO
  refreshToken  String?  // CRIPTOGRAFADO
  expiresAt     DateTime?
  scopes        String?
  icalUrl       String?  // Canvas (feed .ics)
  webhookUrl    String?  // Discord webhook (CRIPTOGRAFADO)
  status        String   @default("connected") // connected | error | revoked
  lastSyncAt    DateTime?
  syncCursor    String?  // syncToken/deltaLink p/ sync incremental
  user          User     @relation(fields:[userId], references:[id], onDelete: Cascade)
  events        CalendarEvent[]
  @@index([userId, provider])
}

// ===== Módulos =====
model Task { 
  id String @id @default(cuid()) 
  userId String 
  title String 
  project String? 
  status String @default("pending") 
  priority Int @default(0) 
  due DateTime?
  createdAt DateTime @default(now())
  completedAt DateTime?
  source String? @default("internal")
  externalId String?
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
}

model WaterLog { 
  id String @id @default(cuid()) 
  userId String 
  amount Int 
  createdAt DateTime @default(now()) 
  user User @relation(fields:[userId], references:[id], onDelete: Cascade) 
  @@index([userId, createdAt]) 
}

model Meal {
  id String @id @default(cuid())
  userId String
  type String
  food String
  grams Int?
  foodId String?
  calories Int?
  protein Int?
  carbs Int?
  fat Int?
  createdAt DateTime @default(now())
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
}

model Food {
  id         String   @id @default(cuid())
  userId     String
  name       String
  brand      String?
  category   String?
  energyKcal Int
  proteinG   Float
  carbsG     Float
  fatG       Float
  goals      String?  // CSV: "hipertrofia,emagrecimento"
  createdAt  DateTime @default(now())
  user       User     @relation(fields:[userId], references:[id], onDelete: Cascade)
  @@index([userId])
}

model CalendarEvent {
  id String @id @default(cuid()) 
  userId String 
  integrationId String?
  source String 
  externalId String? 
  title String
  start DateTime 
  end DateTime 
  allDay Boolean @default(false)
  timezone String?
  location String? 
  url String? 
  category String?
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
  integration Integration? @relation(fields:[integrationId], references:[id], onDelete: SetNull)
  @@unique([integrationId, externalId]) 
  @@index([userId, start])
}

model Goal { 
  id String @id @default(cuid()) 
  userId String 
  title String 
  type String 
  metric String? 
  target Float? 
  current Float @default(0) 
  deadline DateTime? 
  status String @default("active")
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
  dietPlans DietPlan[] 
}

model Habit {
  id String @id @default(cuid())
  userId String
  title String
  frequency String
  streak Int @default(0)
  createdAt DateTime @default(now())
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
  logs HabitLog[]
}

model HabitLog {
  id String @id @default(cuid())
  habitId String
  userId String
  date DateTime @default(now())
  habit Habit @relation(fields:[habitId], references:[id], onDelete: Cascade)
  @@index([habitId, date])
  @@index([userId, date])
}

model FinAccount { 
  id String @id @default(cuid()) 
  userId String 
  name String 
  type String 
  balance Float @default(0) 
  user User @relation(fields:[userId], references:[id], onDelete: Cascade) 
  transactions Transaction[] 
}

model Transaction { 
  id String @id @default(cuid()) 
  userId String 
  accountId String 
  amount Float 
  kind String 
  category String? 
  note String? 
  date DateTime @default(now()) 
  recurring Boolean @default(false) 
  user User @relation(fields:[userId], references:[id], onDelete: Cascade) 
  account FinAccount @relation(fields:[accountId], references:[id], onDelete: Cascade) 
  @@index([userId, date]) 
}

model Budget { 
  id String @id @default(cuid()) 
  userId String 
  category String 
  limit Float 
  period String 
  user User @relation(fields:[userId], references:[id], onDelete: Cascade) 
}

model Alarm {
  id String @id @default(cuid())
  userId String
  label String
  time String
  recurrence String?
  type String
  channels String
  lastFiredAt DateTime?
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
}

model NotificationRule {
  id String @id @default(cuid())
  userId String
  event String
  channel String
  window String?
  enabled Boolean @default(true)
  user User @relation(fields:[userId], references:[id], onDelete: Cascade)
}

// ===== Social =====

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // pending | accepted | blocked
  createdAt   DateTime @default(now())
  requester   User     @relation("sent",     fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User     @relation("received", fields: [addresseeId], references: [id], onDelete: Cascade)
  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
}

model Squad {
  id          String   @id @default(cuid())
  name        String
  type        String   // estudos | academia | compras | metas
  description String?
  coverEmoji  String   @default("🏆")
  inviteCode  String   @unique @default(cuid())
  ownerId     String
  createdAt   DateTime @default(now())
  members     SquadMember[]
  messages    Message[]
  squadGoals  SquadGoal[]
  sessions    ActivitySession[]
  challenges  Challenge[]
  shoppingItems ShoppingItem[]
  scores      UserScore[]
}

model SquadMember {
  id       String   @id @default(cuid())
  squadId  String
  userId   String
  role     String   @default("member") // admin | member
  joinedAt DateTime @default(now())
  squad    Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId],  references: [id], onDelete: Cascade)
  @@unique([squadId, userId])
  @@index([userId])
}

model Message {
  id          String       @id @default(cuid())
  squadId     String?
  dmKey       String?      // "uid1<uid2" sorted lexicographically
  senderId    String
  text        String?
  replyToId   String?
  createdAt   DateTime     @default(now())
  sender      User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  squad       Squad?       @relation(fields: [squadId],  references: [id], onDelete: Cascade)
  replyTo     Message?     @relation("replies", fields: [replyToId], references: [id])
  replies     Message[]    @relation("replies")
  attachments Attachment[]
  reactions   Reaction[]
  @@index([squadId, createdAt])
  @@index([dmKey,   createdAt])
}

model Attachment {
  id        String  @id @default(cuid())
  messageId String
  url       String
  mime      String
  size      Int
  width     Int?
  height    Int?
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String  @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId],    references: [id], onDelete: Cascade)
  @@unique([messageId, userId, emoji])
}

model SquadGoal {
  id        String    @id @default(cuid())
  squadId   String
  title     String
  metric    String?
  target    Float?
  deadline  DateTime?
  createdAt DateTime  @default(now())
  squad     Squad     @relation(fields: [squadId], references: [id], onDelete: Cascade)
}

model ActivitySession {
  id            String    @id @default(cuid())
  userId        String
  squadId       String?
  type          String    // estudos | treino | compras | meta
  startedAt     DateTime
  endedAt       DateTime?
  durationMin   Int?
  tags          String?
  proofImageUrl String?
  notes         String?
  xpEarned      Int       @default(0)
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
  squad         Squad?    @relation(fields: [squadId], references: [id], onDelete: SetNull)
  @@index([userId, createdAt])
  @@index([squadId, createdAt])
}

model ShoppingItem {
  id         String   @id @default(cuid())
  squadId    String
  name       String
  valor      Float?
  bought     Boolean  @default(false)
  boughtById String?
  createdAt  DateTime @default(now())
  squad      Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  @@index([squadId])
}

model Challenge {
  id           String   @id @default(cuid())
  squadId      String
  title        String
  metricTarget Float?
  startAt      DateTime
  endAt        DateTime
  createdAt    DateTime @default(now())
  squad        Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
}

model UserScore {
  id        String   @id @default(cuid())
  userId    String
  squadId   String
  period    String   // "2025-W26" | "2025-06"
  points    Int      @default(0)
  streak    Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId],  references: [id], onDelete: Cascade)
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  @@unique([userId, squadId, period])
  @@index([squadId, period, points])
}

model Badge {
  id       String   @id @default(cuid())
  userId   String
  type     String   // streak_7d | streak_30d | hours_10 | hours_100 | checkin_10
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, type])
}

// ===== Estudos =====

model StudySubject {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())
  sessions  StudySession[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model StudySession {
  id              String    @id @default(cuid())
  userId          String
  subjectId       String?
  sourceType      String    // manual | calendar | task | goal
  sourceId        String?
  label           String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  focusSeconds    Int       @default(0)
  breakSeconds    Int       @default(0)
  status          String    @default("running") // running | paused | completed | canceled
  workMin         Int       @default(25)
  shortBreakMin   Int       @default(5)
  longBreakMin    Int       @default(15)
  cyclesPerLong   Int       @default(4)
  completedCycles Int       @default(0)
  createdAt       DateTime  @default(now())
  subject         StudySubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, startedAt])
}

model StudySettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  workMin        Int     @default(25)
  shortBreakMin  Int     @default(5)
  longBreakMin   Int     @default(15)
  cyclesPerLong  Int     @default(4)
  autoStartBreak Boolean @default(true)
  autoStartWork  Boolean @default(false)
  soundOn        Boolean @default(true)
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ===== Dieta: perfil + plano gerado (semana-molde + rotação) =====

model DietProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  goal          String   // cut | maintain | bulk
  sex           String
  age           Int
  weightKg      Float
  heightCm      Float
  activity      String   // sedentary | light | moderate | active | athlete
  style         String   @default("onivoro") // onivoro | vegetariano | vegano | low_carb | cetogenica
  restrictions  String?  // CSV: glúten,lactose,amendoim...
  mealsPerDay   Int      @default(4)
  preferred     String?  // CSV — alimentos que o usuário quer incluir no plano
  disliked      String?  // CSV
  available     String?  // CSV
  budget        String   @default("moderado") // economico | moderado | sem_restricao — prioriza alimentos baratos ao preencher o que falta
  kcalTarget    Int?
  proteinTarget Int?
  carbTarget    Int?
  fatTarget     Int?
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DietPlan {
  id            String    @id @default(cuid())
  userId        String
  name          String
  status        String    @default("draft") // draft | active | archived
  generatedBy   String    @default("ai")     // ai | manual
  goalId        String?                      // amarra o plano a uma Goal (período = prazo da meta)
  startDate     DateTime  @default(now())
  endDate       DateTime?
  rotation      String    @default("weekly") // weekly = repete a semana-molde até endDate
  kcalTarget    Int
  proteinTarget Int
  carbTarget    Int
  fatTarget     Int
  createdAt     DateTime  @default(now())
  days          PlannedDay[]
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal          Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  @@index([userId, status])
}

model PlannedDay {
  id      String @id @default(cuid())
  planId  String
  weekday Int    // 0=seg ... 6=dom (dia-molde da semana)
  plan    DietPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  meals   PlannedMeal[]
  @@unique([planId, weekday])
}

model PlannedMeal {
  id     String @id @default(cuid())
  dayId  String
  type   String // cafe | almoco | lanche | jantar
  name   String
  order  Int    @default(0)
  day    PlannedDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  items  PlannedItem[]
}

model PlannedItem {
  id        String @id @default(cuid())
  mealId    String
  foodId    String?
  name      String
  quantityG Float
  kcal      Int
  proteinG  Int
  carbG     Int
  fatG      Int
  meal      PlannedMeal @relation(fields: [mealId], references: [id], onDelete: Cascade)
}

/** Banco de alimentos de referência (seed TACO + Open Food Facts + custom), separado do Food (itens pessoais do usuário). */
model FoodCatalogItem {
  id         String  @id @default(cuid())
  source     String  // taco | off | custom
  externalId String?
  name       String
  per100Kcal Int
  per100P    Float
  per100C    Float
  per100F    Float
  tags       String? // CSV: vegano,low-carb...
  @@index([name])
}
